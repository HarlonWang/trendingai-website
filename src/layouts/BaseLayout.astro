---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import { SITE_URL, RSS_URL } from "../config";

interface Props {
    title: string;
    description: string;
    canonicalPath: string;
    bodyClass?: string;
}

const { title, description, canonicalPath, bodyClass } = Astro.props;
const canonical = `${SITE_URL}${canonicalPath}`;
const ogImage = `${SITE_URL}/android_screenshot_zh.png`;
---

<!doctype html>
<html lang="zh-CN">
    <head>
        <script is:inline>
            (function() {
                const stored = (function() {
                    try { return localStorage.getItem("preferred-theme"); } catch (_) { return null; }
                })();
                const theme = (stored === "dark" || stored === "light")
                    ? stored
                    : (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
                document.documentElement.setAttribute("data-theme", theme);
                document.documentElement.style.backgroundColor = theme === "dark" ? "#030712" : "#ffffff";
            })();
        </script>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="description" content={description} />
        <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
        <link rel="icon" type="image/webp" href="/ic_launcher_round.webp" />
        <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
        <link rel="canonical" href={canonical} />
        <link rel="alternate" type="application/rss+xml" title="TrendingAI - 每日技术趋势" href={RSS_URL} />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonical} />
        <meta property="og:image" content={ogImage} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+SC:wght@400;500;700&display=swap" rel="stylesheet" />
        <ViewTransitions />
        <title>{title}</title>
    </head>
    <body class={bodyClass || undefined}>
        <slot />
    </body>
</html>
