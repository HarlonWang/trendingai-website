---
import type { Locale } from "../i18n/types";

interface Props {
    locale: Locale;
    messages: {
        badge?: string;
        title: string;
        subtitle: string;
        placeholder: string;
        cta: string;
        sending: string;
        langLabel: string;
        langZh: string;
        langEn: string;
        privacy: string;
        successNew: string;
        successAlready: string;
        errorInvalid: string;
        errorNetwork: string;
        confirmedMessage: string;
        alreadyMessage: string;
        unsubscribedMessage: string;
    };
}

const { locale, messages } = Astro.props;

const searchParams = Astro.url.searchParams;
const subscribed = searchParams.get("subscribed");
const unsubscribed = searchParams.get("unsubscribed");

const defaultLang = locale === "zh-CN" ? "zh" : "en";

const autoMessage =
    subscribed === "1" ? messages.confirmedMessage
    : subscribed === "already" ? messages.alreadyMessage
    : unsubscribed === "1" ? messages.unsubscribedMessage
    : null;
---

<dialog id="subscribe-modal" class="subscribe-dialog">
    <div class="subscribe-dialog-card">
        <button class="subscribe-dialog-close" id="subscribe-modal-close" aria-label="Close">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
            </svg>
        </button>

        <h2 class="subscribe-title">{messages.title}</h2>
        <p class="subscribe-subtitle">{messages.subtitle}</p>

        {autoMessage && (
            <div class="subscribe-feedback subscribe-feedback--success">
                {autoMessage}
            </div>
        )}

        <form id="subscribe-form" class="subscribe-form" novalidate>
            <div class="subscribe-row">
                <input
                    id="subscribe-email"
                    type="email"
                    required
                    placeholder={messages.placeholder}
                    class="subscribe-input"
                    autocomplete="email"
                />
                <button type="submit" id="subscribe-btn" class="subscribe-btn">
                    {messages.cta}
                </button>
            </div>
            <div class="subscribe-lang">
                <span class="subscribe-lang-label">{messages.langLabel}</span>
                <label class="subscribe-lang-option">
                    <input type="radio" name="lang" value="zh" checked={defaultLang === "zh"} />
                    {messages.langZh}
                </label>
                <label class="subscribe-lang-option">
                    <input type="radio" name="lang" value="en" checked={defaultLang === "en"} />
                    {messages.langEn}
                </label>
            </div>
        </form>

        <div id="subscribe-result" class="subscribe-result" hidden></div>

        <p class="subscribe-privacy">{messages.privacy}</p>
    </div>
</dialog>

<script define:vars={{
    msgSuccessNew: messages.successNew,
    msgSuccessAlready: messages.successAlready,
    msgErrorInvalid: messages.errorInvalid,
    msgErrorNetwork: messages.errorNetwork,
    msgSending: messages.sending,
    msgCta: messages.cta,
    autoShow: !!autoMessage,
}}>
    const dialog = document.getElementById("subscribe-modal");
    const closeBtn = document.getElementById("subscribe-modal-close");
    const form = document.getElementById("subscribe-form");
    const btn = document.getElementById("subscribe-btn");
    const emailInput = document.getElementById("subscribe-email");
    const resultEl = document.getElementById("subscribe-result");

    // 关闭按钮
    closeBtn?.addEventListener("click", () => dialog.close());

    // 点击遮罩关闭
    dialog?.addEventListener("click", (e) => {
        if (e.target === dialog) dialog.close();
    });

    // URL 参数触发时自动打开
    if (autoShow) {
        dialog?.showModal();
    }

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();

        const email = emailInput.value.trim();
        const lang = form.querySelector('input[name="lang"]:checked')?.value || "zh";

        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
            showResult("error", msgErrorInvalid);
            return;
        }

        btn.disabled = true;
        btn.textContent = msgSending;
        resultEl.hidden = true;

        try {
            const resp = await fetch("https://api.trendingai.cn/api/subscribe", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ email, lang }),
            });

            const data = await resp.json();

            if (resp.ok && data.success) {
                if (data.message === "Already subscribed") {
                    showResult("info", msgSuccessAlready);
                } else {
                    showResult("success", msgSuccessNew);
                    emailInput.value = "";
                }
            } else {
                showResult("error", data.error || msgErrorNetwork);
            }
        } catch {
            showResult("error", msgErrorNetwork);
        } finally {
            btn.disabled = false;
            btn.textContent = msgCta;
        }
    });

    function showResult(type, message) {
        resultEl.textContent = message;
        resultEl.className = `subscribe-result subscribe-result--${type}`;
        resultEl.hidden = false;
    }
</script>

<style>
    .subscribe-dialog {
        border: none;
        border-radius: 20px;
        padding: 0;
        max-width: 420px;
        width: calc(100% - 32px);
        background: var(--md-sys-color-surface);
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.18);
        color: var(--md-sys-color-on-surface);
    }

    .subscribe-dialog::backdrop {
        background: rgba(0, 0, 0, 0.36);
        backdrop-filter: blur(3px);
    }

    .subscribe-dialog-card {
        position: relative;
        padding: 28px 24px 22px;
    }

    .subscribe-dialog-close {
        position: absolute;
        top: 14px;
        right: 14px;
        border: none;
        background: transparent;
        color: var(--md-sys-color-on-surface-variant);
        cursor: pointer;
        padding: 4px;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0.6;
        transition: opacity 150ms ease, background 150ms ease;
    }

    .subscribe-dialog-close:hover {
        opacity: 1;
        background: color-mix(in srgb, var(--md-sys-color-on-surface) 8%, transparent);
    }

    .subscribe-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin: 0 0 6px;
        padding-right: 28px;
    }

    .subscribe-subtitle {
        color: var(--md-sys-color-on-surface-variant);
        font-size: 0.88rem;
        line-height: 1.5;
        margin: 0 0 18px;
    }

    .subscribe-feedback {
        padding: 10px 14px;
        border-radius: 10px;
        font-size: 0.88rem;
        margin-bottom: 16px;
    }

    .subscribe-feedback--success {
        background: color-mix(in srgb, var(--md-sys-color-primary) 12%, transparent);
        color: var(--md-sys-color-on-surface);
    }

    .subscribe-feedback--info {
        background: var(--md-sys-color-surface-container);
        color: var(--md-sys-color-on-surface-variant);
    }

    .subscribe-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .subscribe-row {
        display: flex;
        gap: 8px;
    }

    .subscribe-input {
        flex: 1;
        padding: 10px 14px;
        border-radius: 10px;
        border: 1.5px solid var(--md-sys-color-outline);
        background: var(--md-sys-color-surface);
        color: var(--md-sys-color-on-surface);
        font-size: 0.9rem;
        outline: none;
        transition: border-color 150ms ease;
        min-width: 0;
    }

    .subscribe-input::placeholder {
        color: var(--md-sys-color-on-surface-variant);
        opacity: 0.6;
    }

    .subscribe-input:focus {
        border-color: var(--md-sys-color-primary);
    }

    .subscribe-btn {
        padding: 10px 18px;
        border-radius: 10px;
        border: none;
        background: var(--md-sys-color-primary);
        color: var(--md-sys-color-on-primary);
        font-size: 0.9rem;
        font-weight: 600;
        cursor: pointer;
        white-space: nowrap;
        transition: opacity 150ms ease;
    }

    .subscribe-btn:disabled {
        opacity: 0.6;
        cursor: not-allowed;
    }

    .subscribe-lang {
        display: flex;
        align-items: center;
        gap: 14px;
        font-size: 0.82rem;
        color: var(--md-sys-color-on-surface-variant);
    }

    .subscribe-lang-option {
        display: flex;
        align-items: center;
        gap: 4px;
        cursor: pointer;
    }

    .subscribe-result {
        margin-top: 10px;
        padding: 10px 14px;
        border-radius: 10px;
        font-size: 0.88rem;
    }

    .subscribe-result--success {
        background: color-mix(in srgb, var(--md-sys-color-primary) 12%, transparent);
        color: var(--md-sys-color-on-surface);
    }

    .subscribe-result--info {
        background: var(--md-sys-color-surface-container);
        color: var(--md-sys-color-on-surface-variant);
    }

    .subscribe-result--error {
        background: color-mix(in srgb, #b3261e 12%, transparent);
        color: var(--md-sys-color-on-surface);
    }

    .subscribe-privacy {
        margin: 14px 0 0;
        font-size: 0.78rem;
        color: var(--md-sys-color-on-surface-variant);
        opacity: 0.7;
    }
</style>
