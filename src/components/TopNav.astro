---
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
    activeRoute: "home" | "feed" | "app";
}

const { activeRoute } = Astro.props;

const links = [
    { id: "home", label: "首页", href: "/" },
    { id: "feed", label: "Feed", href: "/feed/" },
    { id: "app", label: "App", href: "/app/" },
] as const;
---

<header class="top-bar fixed top-0 left-0 right-0 z-50 transition-shadow duration-300">
    <nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4 sm:px-6">
        <a class="flex items-center gap-2.5" href="/" aria-label="首页">
            <img class="size-8 rounded-full" src="/ic_launcher.png" alt="TrendingAI Logo" loading="eager" />
            <span class="text-base font-extrabold text-on-surface">Trending AI</span>
        </a>
        <div class="flex items-center gap-1">
            {links.map((link) => (
                <a
                    class:list={[
                        "rounded-lg px-3 py-1.5 text-sm font-medium transition-colors",
                        activeRoute === link.id
                            ? "bg-primary text-on-primary"
                            : "text-on-surface-variant hover:bg-surface-container hover:text-on-surface",
                    ]}
                    href={link.href}
                >
                    {link.label}
                </a>
            ))}
            <a
                class="ml-1 flex size-8 items-center justify-center rounded-lg text-on-surface-variant transition-colors hover:bg-surface-container hover:text-on-surface"
                href="https://github.com/HarlonWang/trendingai-website"
                target="_blank"
                rel="noopener noreferrer"
                title="Star on GitHub"
                aria-label="Star on GitHub"
            >
                <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
                </svg>
            </a>
            <div>
                <ThemeToggle />
            </div>
        </div>
    </nav>
</header>

<script is:inline>
    document.addEventListener("astro:page-load", function() {
        var header = document.querySelector(".top-bar");
        if (!header) return;
        function onScroll() {
            if (window.scrollY > 10) {
                header.classList.add("scrolled");
            } else {
                header.classList.remove("scrolled");
            }
        }
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
    });
</script>
