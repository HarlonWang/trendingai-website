---
import BaseLayout from "../layouts/BaseLayout.astro";
import TopNav from "../components/TopNav.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
    title="TrendingAI - 每日技术趋势精选"
    description="聚合 GitHub、Hacker News、Product Hunt 热门项目，AI 智能分析，每日精选推荐"
    canonicalPath="/"
>
    <TopNav activeRoute="home" />
    <main class="mx-auto max-w-5xl px-4 pt-20 pb-8 sm:px-6">
        <!-- P2: Picks 精选区 -->
        <section id="picks" class="mb-12">
            <div class="mb-6 flex items-baseline justify-between">
                <h2 class="text-xl font-bold text-on-surface">今日精选</h2>
                <span class="text-sm text-on-surface-variant" id="picks-date"></span>
            </div>
            <div id="picks-container" class="space-y-6">
                <!-- 骨架屏 -->
                <div class="grid gap-4 md:grid-cols-3">
                    {[1, 2, 3].map(() => (
                        <div class="h-48 animate-pulse rounded-xl bg-surface-container" />
                    ))}
                </div>
            </div>
        </section>

        <!-- P3: 三源横滑预览 -->
        <section id="sources" class="space-y-10">
            {["GitHub 热门", "Hacker News 热议", "Product Hunt 新品"].map((title) => (
                <div>
                    <div class="mb-4 flex items-baseline justify-between">
                        <h2 class="text-lg font-bold text-on-surface">{title}</h2>
                        <a class="text-sm text-on-surface-variant transition-colors hover:text-on-surface" href="/feed/">
                            查看全部 &rarr;
                        </a>
                    </div>
                    <div class="flex gap-4 overflow-x-auto pb-2 snap-x snap-mandatory">
                        {[1, 2, 3, 4].map(() => (
                            <div class="h-36 w-72 flex-shrink-0 snap-start animate-pulse rounded-xl bg-surface-container" />
                        ))}
                    </div>
                </div>
            ))}
        </section>
    </main>
    <Footer />
</BaseLayout>
